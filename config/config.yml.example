# yaml-language-server: $schema=../public/config.schema.json

# -- Theme
#
# Accent-only presets (just the accent color, neutral base unchanged):
#   orange (default), blue, green, purple, rose, mono
#
# Full-palette presets (paired light + dark, the toggle still works):
#   catppuccin     Latte / Mocha
#   tokyo-night    Day / Night
#   dracula        Alucard / Dracula
#   nord           Snow Storm / Polar Night
#   gruvbox        Light medium / Dark medium
#
# Optionally override the accent color with any CSS color value (hex,
# rgb(), oklch(), ...). The custom value applies to both light and dark.
#
# Cards can also pick up a configurable backdrop blur ("glassiness").
# Levels (none | subtle | regular | clear) loosely follow Apple's Liquid
# Glass naming. The effect is automatically dropped when the user has
# prefers-reduced-transparency set.
# theme:
#   preset: catppuccin
#   primary: "#ff5733"
#   glass: regular

# -- Widgets
#
# Widgets to include in the dashboard, order of widgets here determine
# the order of widgets on the dashboard.
#
# Built-in widget types:
#   host-stats             combined uptime, load, memory and CPU stats
#   teslamate              battery, range, charging state (needs teslamate.mqtt)
#   teslamate-stats        lifetime + 30-day km, kWh, cost (needs teslamate.postgres)
#   teslamate-recent       last N drives or charges (needs teslamate.postgres)
#   teslamate-efficiency   Wh/km sparkline over 30 days (needs teslamate.postgres)
#   teslamate-cost         monthly cost split home/public (needs teslamate.postgres)
#   teslamate-battery      rated range / battery degradation (needs teslamate.postgres)
#   teslamate-charge-curve power vs SoC for the last charge (needs teslamate.postgres)
#   teslamate-performance  top speed / peak power / longest drive (needs teslamate.postgres)
#   teslamate-tpms         latest tyre pressures (needs teslamate.postgres)
#   teslamate-odometer     current odometer reading (needs teslamate.postgres)
#   teslamate-location     last known position + map link (needs teslamate.postgres)
#   arr                    queue + upcoming calendar for sonarr/radarr/lidarr/readarr
#
# Sizes: small (1 col), medium (2 cols), large (3 cols or full row).

# -- TeslaMate
#
# Top-level connection settings shared by all teslamate widgets.
# teslamate:
#   mqtt:
#     url: mqtt://mosquitto:1883        # required for the teslamate live widget
#     username: ${MQTT_USERNAME}        # optional
#     password: ${MQTT_PASSWORD}        # optional
#     topic_prefix: teslamate           # default: "teslamate"
#   postgres:
#     host: teslamate-db                # required for teslamate-stats/recent/efficiency/cost
#     port: 5432
#     database: teslamate
#     user: teslamate
#     password: ${TESLAMATE_DB_PASSWORD}
#     ssl: false

widgets:
  - type: host-stats
    size: medium

  # - type: teslamate
  #   size: medium
  #   car_id: 1     # TeslaMate car id (default: "1")

  # - type: teslamate-stats
  #   size: medium
  #   car_id: 1

  # - type: teslamate-recent
  #   size: medium
  #   car_id: 1
  #   mode: drives   # drives | charges
  #   limit: 3       # 1-20

  # - type: teslamate-efficiency
  #   size: medium
  #   car_id: 1

  # - type: teslamate-cost
  #   size: medium
  #   car_id: 1

  # - type: teslamate-battery
  #   size: medium
  #   car_id: 1

  # - type: teslamate-charge-curve
  #   size: medium
  #   car_id: 1

  # - type: teslamate-performance
  #   size: medium
  #   car_id: 1

  # - type: teslamate-tpms
  #   size: medium
  #   car_id: 1

  # - type: teslamate-odometer
  #   size: small
  #   car_id: 1

  # - type: teslamate-location
  #   size: medium
  #   car_id: 1

  # - type: arr
  #   size: medium
  #   service: sonarr                  # sonarr | radarr | lidarr | readarr
  #   url: http://sonarr:8989          # required
  #   api_key: ${SONARR_API_KEY}       # required
  #   title: TV                        # optional, defaults to capitalised service name
